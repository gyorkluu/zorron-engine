# ===== General =====
NODE_ENV=development
LOG_LEVEL=info
REQUEST_ID_HEADER=x-request-id

# ===== Server (apps/zorron-server) =====
PORT=3000
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
# Local development (matches docker-compose.yml). Override for remote dev.
DATABASE_URL=postgresql://zorron:zorron@localhost:5432/zorron

# Redis
REDIS_URL=redis://localhost:6379

# JWT (used in MIG-003)
# Generate a strong secret with: `openssl rand -hex 32` (must be >= 32 chars).
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Storage Provider: local | s3 | r2
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./uploads
STORAGE_BASE_URL=http://localhost:3000/uploads

# Object Storage (when STORAGE_PROVIDER=s3|r2)
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=

# Assets
ASSET_MAX_SIZE_MB=50
ASSET_ALLOWED_MIMES=image/*,audio/*,video/*,font/*

# Feature Flags (server-side)
FEATURE_VECTOR_3D=false
VECTOR_SECT_COUNT=20
FEATURE_CLOUD_SYNC=true

# ===== Editor (apps/zorron-editor) =====
VITE_API_BASE_URL=http://localhost:3000
VITE_FEATURE_VECTOR_3D=false
VITE_FEATURE_CLOUD_SYNC=true
