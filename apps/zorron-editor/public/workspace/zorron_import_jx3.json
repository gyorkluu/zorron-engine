    { "id": "frag_note", "name": "苏白月的笔记", "description": "泛黄的笔记记载了苍灵草水能产生短暂的'气息全无'假死现象。", "relatedSectIds": [ "yaozong", "wanhua" ] },
    { "id": "frag_secret", "name": "唐简的遗泽", "description": "残破典籍中夹着关于苍灵草能'隐匿生机'的秘辛。", "relatedSectIds": [ "tangmen", "yantian" ] },
    { "id": "frag_move", "name": "公孙二娘的变招", "description": "萧白胭曾言，二娘的变招往往生于绝境，理论上可克制任何奇功。", "relatedSectIds": [ "qixiu", "wudu" ] },
