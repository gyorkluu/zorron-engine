    { "id": "frag_breath_1", "name": "小沙弥的异常", "description": "极度惊恐下，小沙弥的呼吸声呈现出一种奇特的规律。", "relatedSectIds": [ "shaolin", "daozong" ] },
    { "id": "frag_breath_2", "name": "渡法的呼吸", "description": "渡法圆寂前的三次呼吸极其沉闷，竟能让周围狂暴的人群瞬间恢复神智。", "relatedSectIds": [ "shaolin", "chunyang" ] }
