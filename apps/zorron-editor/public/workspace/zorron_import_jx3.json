    { "id": "frag_porcelain", "name": "唐怀仁的碎瓷", "description": "火雷阵残骸显示，震动中存在一个完全寂静的视觉盲区。", "relatedSectIds": [ "tangmen", "lingxue" ] },
    { "id": "frag_sword_intent", "name": "叶英的剑意", "description": "剑气凝霜，你察觉到谢采极度畏惧这种寒意，这似乎是他功法的克星。", "relatedSectIds": [ "cangjian", "chunyang" ] },
