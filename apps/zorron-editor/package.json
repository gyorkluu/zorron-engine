    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "framer-motion": "^12.40.0",
    "lodash.isequal": "^4.5.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.1.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.79.0",
    "react-router-dom": "^7.1.1",
    "tailwind-merge": "^2.6.0",
    "uuid": "^14.0.0",
