{
  "name": "zorron-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:h5": "vite build --config vite.config.h5.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
