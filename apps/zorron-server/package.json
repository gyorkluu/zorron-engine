{
  "name": "zorron-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=.env --watch src/server.ts",
    "start": "bun --env-file=.env src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:rollback": "drizzle-kit drop"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@aws-sdk/s3-request-presigner": "^3.1071.0",
    "@elysiajs/bearer": "^1.2.0",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/static": "^1.4.10",
    "@elysiajs/swagger": "^1.2.0",
    "bcrypt": "^6.0.0",
    "cookie": "^1.1.1",
    "drizzle-orm": "^0.38.3",
    "elysia": "^1.2.0",
    "ioredis": "^5.4.2",
    "jose": "^6.2.3",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bun": "^1.1.14",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
